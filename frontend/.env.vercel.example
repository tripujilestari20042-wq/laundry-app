# ============================================================
# Environment Variables — Vercel (Frontend)
# Salin ke: Vercel Dashboard → Project → Settings → Environment Variables
# ============================================================

# --- WAJIB ---
NEXT_PUBLIC_SUPABASE_URL=https://upekqyrncipkgbpazrzm.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# URL backend production (Express API) — opsional.
# Kosongkan atau jangan set jika belum deploy Railway.
# JANGAN isi dengan URL Vercel frontend!
NEXT_PUBLIC_API_URL=https://your-backend-production.up.railway.app

# URL frontend Vercel Anda:
NEXT_PUBLIC_APP_URL=https://laundry-app-liart.vercel.app

# --- SERVER-ONLY (jangan pakai prefix NEXT_PUBLIC_) ---
# Diperlukan untuk admin hapus/buat pengguna via API Vercel:
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- OPSIONAL ---
NEXT_PUBLIC_LAUNDRY_LAT=-6.2088
NEXT_PUBLIC_LAUNDRY_LNG=106.8456
NEXT_PUBLIC_LAUNDRY_ADDRESS=Jl. Contoh No. 123, Jakarta
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=

# ============================================================
# SETELAH DEPLOY
# ============================================================
# Supabase → Auth → URL Configuration:
#   Site URL: https://laundry-app-liart.vercel.app
#   Redirect: https://laundry-app-liart.vercel.app/auth/callback
#
# Backend Railway → FRONTEND_URL=https://laundry-app-liart.vercel.app
