# ============================================================
# Environment Variables — Vercel (Frontend)
# Salin ke: Vercel Dashboard → Project → Settings → Environment Variables
# ============================================================

# --- WAJIB ---
NEXT_PUBLIC_SUPABASE_URL=https://upekqyrncipkgbpazrzm.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# URL backend production (Express API) — JANGAN localhost di production!
# Contoh: https://laundry-api.railway.app atau https://api.yourdomain.com
NEXT_PUBLIC_API_URL=https://your-backend-production-url.com

# URL frontend Vercel (untuk OAuth redirect & link absolut)
# Contoh: https://laundry-app.vercel.app
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# --- OPSIONAL (fallback peta jika API store belum tersedia) ---
NEXT_PUBLIC_LAUNDRY_LAT=-6.2088
NEXT_PUBLIC_LAUNDRY_LNG=106.8456
NEXT_PUBLIC_LAUNDRY_ADDRESS=Jl. Contoh No. 123, Jakarta

# --- OPSIONAL ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=

# ============================================================
# CATATAN SETELAH DEPLOY
# ============================================================
# 1. Supabase → Authentication → URL Configuration:
#    - Site URL: https://your-app.vercel.app
#    - Redirect URLs: https://your-app.vercel.app/auth/callback
#
# 2. Google Cloud Console → OAuth redirect URI (tetap Supabase):
#    https://upekqyrncipkgbpazrzm.supabase.co/auth/v1/callback
#
# 3. Backend (Railway/Render/VPS) → FRONTEND_URL=https://your-app.vercel.app
#    dan CORS harus mengizinkan origin Vercel Anda.
