# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend API
NEXT_PUBLIC_API_URL=http://localhost:4000

# Laundry Store Location (for map default center)
NEXT_PUBLIC_LAUNDRY_LAT=-6.2088
NEXT_PUBLIC_LAUNDRY_LNG=106.8456
NEXT_PUBLIC_LAUNDRY_ADDRESS=Jl. Contoh No. 123, Jakarta

# Google Maps (optional)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# App URL (for OAuth redirects — harus sama dengan origin browser)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Midtrans (optional — E-Wallet/Transfer; client key juga diambil dari API /api/payments/config)
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=your-midtrans-client-key

# Google OAuth — salin URL ini ke Google Cloud Console → Credentials → Authorized redirect URIs:
# https://upekqyrncipkgbpazrzm.supabase.co/auth/v1/callback
# (BUKAN http://localhost:3000/auth/callback — itu untuk Supabase URL Configuration saja)
